    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.1",
    "three": "^0.183.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.12"
