// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum AdminRole {
    USER
    OWNER
    ADMIN
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    passwordHash  String?
    accounts      Account[]
    sessions      Session[]
    posts         Post[]

    adminAuditLogs AdminAuditLog[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model AdminWhitelist {
    id        String    @id @default(cuid())
    email     String    @unique
    role      AdminRole @default(USER)
    isActive  Boolean   @default(true)
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}

model Company {
    id          String   @id @default(cuid())
    slug        String   @unique
    name        String
    description String
    location    String?
    logoUrl     String?
    themeColor  String?
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    interviewProfiles InterviewProfile[]
    portals           CompanyPortal[]

    @@index([isActive])
}

model InterviewProfile {
    id              String   @id @default(cuid())
    companyId       String
    roleTitle       String
    documentKey     String
    documentTitle   String
    documentText    String
    systemPrompt    String?
    questionPrompt  String?
    evaluationPrompt String?
    questionCount   Int      @default(5)
    passScore       Int      @default(72)
    temperature     Float    @default(0.35)
    maxOutputTokens Int      @default(1600)
    isActive        Boolean  @default(true)
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    @@index([companyId, isActive])
    @@unique([companyId, documentKey])
}

model CompanyPortal {
    id               String   @id @default(cuid())
    companyId        String
    activationRadius Float    @default(1.6)
    positionX        Float
    positionY        Float    @default(0.2)
    positionZ        Float
    rotationY        Float    @default(0)
    logoUrl          String?
    themeColor       String?
    isActive         Boolean  @default(true)
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

    @@index([companyId, isActive])
}

model GlobalLlmConfig {
    id              String   @id @default("global")
    provider        String
    model           String
    baseUrl         String?
    temperature     Float    @default(0.35)
    maxOutputTokens Int      @default(1600)
    updatedAt       DateTime @updatedAt
}

model AdminAuditLog {
    id        String   @id @default(cuid())
    actorId   String?
    action    String
    entity    String
    entityId  String?
    before    Json?
    after     Json?
    createdAt DateTime @default(now())

    actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

    @@index([actorId])
    @@index([entity, entityId])
}
